# Secrets & local config — never commit
.env
.env.*
!.env.example
config.json
settings.json
preferences.json
.secrets.json
.token
.token.*

# Generated data snapshots (live data stays local)
data/snapshot*.json
data/*.local.json

# Dependencies & build output
node_modules/
dist/
# note: build/ holds packaging resources (app icon) and IS committed; output is dist/

# Logs
*.log
logs/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
