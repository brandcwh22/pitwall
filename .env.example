# Pit Wall — environment variables
# Copy to .env (git-ignored) OR export these in your shell before `npm start`.
# Each connection in config.json references one of these by name (tokenEnv).

# Shortcut API token — https://app.shortcut.com/settings/account/api-tokens
PITWALL_TOKEN_PRIMARY=

# Jira API token — https://id.atlassian.com/manage-profile/security/api-tokens
# PITWALL_TOKEN_JIRA=

# Optional: port the dashboard serves on (default 4200)
# PORT=4200
