{
  "name": "pitwall",
  "version": "2.0.0-alpha.0",
  "description": "Pit Wall — a provider-agnostic QA telemetry dashboard. Plug in your own ticketing platform (Shortcut, Jira, …) and watch your QA metrics like an F1 broadcast.",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "pitwall": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "app": "electron .",
    "dist": "electron-builder --dir",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "qa",
    "dashboard",
    "shortcut",
    "jira",
    "ticketing",
    "telemetry",
    "f1",
    "electron"
  ],
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "electron": "^43.1.1"
  },
  "build": {
    "appId": "com.pitwall.qa",
    "productName": "Pit Wall",
    "files": [
      "electron/**",
      "src/**",
      "public/**",
      "data/**",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        "dir"
      ]
    }
  }
}
