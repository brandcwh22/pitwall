{
  "name": "pitwall",
  "version": "2.0.0-alpha.0",
  "description": "Pit Wall — a provider-agnostic QA telemetry dashboard. Plug in your own ticketing platform (Shortcut, Jira, …) and watch your QA metrics like an F1 broadcast.",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "pitwall": "src/server.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "app": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "qa",
    "dashboard",
    "shortcut",
    "jira",
    "ticketing",
    "telemetry",
    "f1",
    "electron"
  ],
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.pitwall.qa",
    "productName": "Pit Wall",
    "files": [
      "electron/**",
      "src/**",
      "public/**",
      "data/**",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Development",
      "target": [
        "AppImage"
      ]
    }
  }
}
